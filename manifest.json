{
  "manifest_version": 3,
  "name": "Meridian",
  "version": "1.0.0",
  "description": "Spatial tab command center",
  "chrome_url_overrides": {
    "newtab": "meridian.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "tabGroups", "storage", "scripting"],
  "host_permissions": ["<all_urls>"],
  "commands": {
    "focus-meridian": {
      "suggested_key": {
        "default": "Ctrl+Shift+M"
      },
      "description": "Focus Meridian tab"
    }
  },
  "icons": {
    "16": "img/icon16.png",
    "32": "img/icon32.png",
    "48": "img/icon48.png",
    "128": "img/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "img/icon16.png",
      "32": "img/icon32.png",
      "48": "img/icon48.png",
      "128": "img/icon128.png"
    }
  }
}
